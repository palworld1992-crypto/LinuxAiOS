# Đợi 10 giây sau khi ngừng gõ mới gửi (Tránh gửi liên tục khi đang viết code)
OPENCODE_API_DEBOUNCE=10000

# Chỉ cho phép gửi 1 yêu cầu duy nhất tại một thời điểm
OPENCODE_MAX_CONCURRENT=1

# Nếu server báo bận (429), đợi
OPENCODE_RETRY_DELAY=20000

# Thời gian tối thiểu giữa các request (tránh quá tải)
OPENCODE_MIN_REQUEST_INTERVAL=15000

